# Agent Memory Configuration Example
# Copy this to .env and fill in your values

# AI API Configuration
AI_BASE_URL=https://ai.chen.rs/v1
AI_API_KEY=your_api_key_here

# Model Selection
AI_MODEL_FAST=gpt-5.4-mini
AI_MODEL_BALANCED=gpt-5.5
AI_MODEL_STRONG=gpt-5.5

# Embedding Configuration (Gemini)
# GEMINI_API_KEY=your_gemini_key
# GEMINI_API_KEYS=key1,key2,key3
# GEMINI_EMBED_MODEL=gemini-embedding-2

# Storage Configuration
# AGENT_MEMORY_ROOT=/Users/yourname/.agents/memory
